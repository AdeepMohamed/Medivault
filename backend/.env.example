# MediVault Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Server ─────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── JWT ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_at_least_64_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_at_least_64_chars

# ── Supabase ───────────────────────────────────────
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# SUPABASE_ANON_KEY is NOT needed (we use service role on backend)

# ── Email (Gmail SMTP) ─────────────────────────────
# Enable "App Passwords" in Gmail: myaccount.google.com/apppasswords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# ── Groq AI ────────────────────────────────────────
# Get from: console.groq.com
GROQ_API_KEY=your_groq_api_key_here
